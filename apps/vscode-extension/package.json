{
  "name": "bilibop-ai-sidebar",
  "displayName": "Bilibop AI Sidebar",
  "description": "Sidebar IA branchée sur harness maison",
  "version": "0.0.1",
  "publisher": "bilibop",
  "private": true,
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:bilibop-ai-sidebar.helloWorld",
    "onView:bilibop.chatView",
    "onCommand:bilibop-ai-sidebar.indexWorkspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "bilibop.chatView",
          "type": "webview",
          "name": "Bilibop AI"
        }
      ]
    },
    "commands": [
      {
        "command": "bilibop-ai-sidebar.helloWorld",
        "title": "Bilibop AI: Hello World"
      },
      {
        "command": "bilibop-ai-sidebar.indexWorkspace",
        "title": "Bilibop: Index Workspace"
      }
    ]
  },
  "scripts": {
    "precompile": "pnpm --filter harness-core run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc -p ./ --noEmit",
    "pretest": "pnpm run compile",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "harness-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.7.0"
  }
}
