{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Bilibop Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/vscode-extension/out/**/*.js"
      ],
      "preLaunchTask": "pnpm: compile extension"
    }
  ]
}
